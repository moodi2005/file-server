    "dev": "tsc && nodemon ./build/index.js",
    "test": "tsc && node --test \"build/__tests__/*.test.js\""
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/busboy": "^1.5.3",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
