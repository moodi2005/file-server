{
  "name": "@webkn/file-server",
  "version": "1.0.1",
  "type": "module",
  "description": "Upload and serve files",
  "main": "build/index.js",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "busboy": "^1.6.0",
    "mime": "^4.0.1",
    "sharp": "^0.33.5"
  },
  "scripts": {
    "b": "tsc",
    "build:watch": "tsc -w",
    "bundle": "tsc && node ./scripts/bundle.mjs",
