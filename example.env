# File server configuration.
#
# The process reads plain environment variables — it does not parse this file
# itself. Use it with:
#   docker run --env-file example.env ...
#   docker compose (env_file: example.env)
#   set -a && . ./example.env && set +a   # plain shell
#
# Every value below is the default except accessUrl, which is required.


# ── Required ────────────────────────────────────────────────────────────────

# Auth endpoint. Receives POST { policy, part, onlyToken } with the user's
# token in a `token` header.
# The server REFUSES TO START without this — there is no auth-off mode.
accessUrl=http://user/access


# ── Basics ──────────────────────────────────────────────────────────────────

port=2005

# Must be a persistent volume. Holds blobs/, tmp/, files.db and jobs.db.
# tmp/ has to stay on the same filesystem as blobs/ or every upload fails with
# EXDEV — publishing a file is a rename, and rename does not cross filesystems.
dataDir=/data

# Baked into every file id (n1-202608-…). Give each node its own value; ids
# then say which node holds the file, with nothing shared between them.
nodeId=n1

# debug | info | warn | error
logLevel=info


# ── Workers ─────────────────────────────────────────────────────────────────

# HTTP workers. Left unset it reads the cgroup cpu quota, falling back to core
# count. SET IT EXPLICITLY IF YOU USE --cpus: os.cpus() reports the *host's*
# cores, so a 2-cpu container on a 64-core host would otherwise fork 64 workers.
# httpWorkers=4

# Compression processes. Separate from the http workers so a burst of sharp
# work cannot starve request serving.
jobWorkers=2


# ── Storage layout ──────────────────────────────────────────────────────────

# Files per bucket directory, then a fresh bucket. Guards against pathological
# directory sizes; anything from a few hundred to ~10k performs the same.
bucketSize=5000


# ── Upload limits ───────────────────────────────────────────────────────────

# Per file. 100 MB.
maxFileSize=104857600

# Per request.
maxFilesPerRequest=10

# Per user, per UTC day, keyed on the _id the access service returns. 3 GB.
# Per-day rather than lifetime: files are never deleted, so the useful question
# is how fast the disk can fill, and a lifetime cap would eventually lock the
# server out for good. 0 disables.
maxBytesPerUserPerDay=3221225472

# Same idea, on file count. 0 disables.
maxUploadsPerUserPerDay=10000


# ── Disk guard ──────────────────────────────────────────────────────────────

# Uploads answer 507 below this much free space. The higher of the two floors
# wins. Stopping early matters: a full disk also stops SQLite writing, so the
# whole node dies rather than just uploads. Watch /health → disk.freePercent.
minFreeDiskBytes=5368709120
minFreeDiskPercent=5


# ── Access service ──────────────────────────────────────────────────────────

# Sent as `policy` in the request body.
accessPolicy=fileServer

# Sent as `part`. Upload checks permissions; download only validates the token
# (onlyToken=true).
accessPartUpload=upload
accessPartDownload=download

# Success cache, ms. This is also the revocation delay — a token you revoke
# still works for this long. Kept short to match the other services.
accessCacheTtl=10000

# Failure cache, ms. Without it, a flood of junk tokens turns this server into
# an amplifier pointed at your own auth service.
accessNegativeCacheTtl=60000

# Hard timeout, ms. fetch has no default timeout in Node: without this a hung
# auth service hangs every upload behind it until the workers fill up.
accessTimeout=2000

# LRU bound. Failures are cached too, so an unbounded cache is a memory DoS.
accessCacheMax=10000

# Consecutive transport failures before the breaker opens, and how long it
# stays open (ms). A dead auth service then costs one timeout per window
# instead of one per request.
accessBreakerThreshold=5
accessBreakerReset=10000


# ── Legacy tree ─────────────────────────────────────────────────────────────

# Point at the old uploads/ directory to keep urls the previous server handed
# out resolving. Read-only; nothing is moved or rewritten. Leave unset to turn
# the route off.
# legacyDir=/data/legacy-uploads
# legacyUrlPrefix=download


# ── Housekeeping ────────────────────────────────────────────────────────────

# Orphaned tmp files from uploads that died mid-stream. Safe by construction:
# nothing in tmp/ is ever referenced by the database.
tmpSweepMaxAge=21600000
tmpSweepInterval=3600000
